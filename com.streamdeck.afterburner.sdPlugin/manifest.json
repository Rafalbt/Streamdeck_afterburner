{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.streamdeck.afterburner",
  "Name": "Afterburner Sensors",
  "Version": "0.1.19.0",
  "Author": "hwinfi",
  "Description": "Show any MSI Afterburner sensor (temperature, load, clock, ...) on a key as text or a mini chart.",
  "Category": "Afterburner Sensors",
  "CategoryIcon": "imgs/category-icon",
  "Icon": "imgs/plugin-icon",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "CodePath": "bin/plugin.js",
  "Actions": [
    {
      "Name": "Sensor",
      "UUID": "com.streamdeck.afterburner.sensor",
      "Icon": "imgs/action-icon",
      "Tooltip": "Display an MSI Afterburner sensor value or chart",
      "PropertyInspectorPath": "ui/pi.html",
      "SupportedInMultiActions": false,
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/key-icon",
          "ShowTitle": false
        }
      ]
    },
    {
      "Name": "Fan control",
      "UUID": "com.streamdeck.afterburner.fan",
      "Icon": "imgs/action-icon",
      "Tooltip": "Control GPU fan speed with a Stream Deck + dial",
      "Controllers": [
        "Encoder"
      ],
      "Encoder": {
        "layout": "$B1",
        "TriggerDescription": {
          "Rotate": "Adjust fan %",
          "Push": "Toggle auto/manual"
        }
      },
      "States": [
        {
          "Image": "imgs/action-icon"
        }
      ]
    },
    {
      "Name": "Network download",
      "UUID": "com.streamdeck.afterburner.netdown",
      "Icon": "imgs/action-icon",
      "Tooltip": "Current network download rate",
      "PropertyInspectorPath": "ui/net-pi.html",
      "SupportedInMultiActions": false,
      "UserTitleEnabled": false,
      "States": [{ "Image": "imgs/key-icon", "ShowTitle": false }]
    },
    {
      "Name": "Network upload",
      "UUID": "com.streamdeck.afterburner.netup",
      "Icon": "imgs/action-icon",
      "Tooltip": "Current network upload rate",
      "PropertyInspectorPath": "ui/net-pi.html",
      "SupportedInMultiActions": false,
      "UserTitleEnabled": false,
      "States": [{ "Image": "imgs/key-icon", "ShowTitle": false }]
    }
  ]
}